{
  "name": "live2d",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/lib/live2d.umd.cjs",
  "module": "./dist/lib/live2d.js",
  "exports": {
    ".": {
      "import": "./dist/lib/live2d.js",
      "require": "./dist/lib/live2d.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite --open",
    "sync:custom-tool-actions": "node ./scripts/generate-custom-tool-actions.mjs",
    "build": "pnpm sync:custom-tool-actions && tsc -b && vite build && vite build --config vite.halo.config.ts",
    "check": "pnpm sync:custom-tool-actions && biome check --write"
  },
  "dependencies": {
    "@lit/context": "^1.1.3",
    "@lit/react": "^1.0.7",
    "iconify-icon": "^2.3.0",
    "lit": "^3.2.1",
    "@pixi/sound": "^6.0.1",
    "pixi.js": "^8.13.1",
    "query-string": "^9.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "untitled-pixi-live2d-engine": "^1.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@unocss/postcss": "^65.4.3",
    "@vitejs/plugin-react": "^4.3.4",
    "ts-lit-plugin": "^2.0.2",
    "unocss": "^65.4.3",
    "vite": "^6.1.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
